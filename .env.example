# Power Platform 環境設定
DATAVERSE_URL=https://{org}.crm7.dynamics.com/
TENANT_ID={your-tenant-id}

# ソリューション設定
SOLUTION_NAME=IncidentManagement
PUBLISHER_PREFIX=geek

# PAC CLI 認証プロファイル
PAC_AUTH_PROFILE=IncidentManager

# メール通知先（Power Automate フロー用・オプション）
ADMIN_EMAIL=admin@example.com

# Copilot Studio Bot ID（Phase 3・オプション）
BOT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# === MSAL (ブラウザ認証 - Vite 用 VITE_ prefix) ===
VITE_MSAL_TENANT_ID={your-tenant-id}
VITE_MSAL_CLIENT_ID={your-spa-client-id}

# === SharePoint (Vite 用 VITE_ prefix) ===
VITE_SP_SITE_ID={tenant}.sharepoint.com,{site-id-1},{site-id-2}
VITE_SP_LIST_CUSTOMERS={list-id}
VITE_SP_LIST_SYSTEMS={list-id}
VITE_SP_LIST_WORKTYPES={list-id}
VITE_SP_LIST_REPORTS={list-id}
VITE_SP_LIST_PLANS={list-id}

# === SharePoint スクリプト用 ===
SP_GROUP_ID={teams-group-id}

# === Teams チャネル通知 ===
VITE_TEAMS_TEAM_ID={teams-team-id}
VITE_TEAMS_CHANNEL_ID={teams-channel-id}

# === URL / デプロイ設定（オプション） ===
# GitHub Pages のサブパス公開時: /manmarudairyreport/
# カスタムドメイン直下公開時: /
VITE_APP_BASE_PATH=/manmarudairyreport/

# GitHub Actions Secret 側で設定する項目（.env ではなく Secrets 推奨）
# GH_PAGES_CUSTOM_DOMAIN=app.example.com
